{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.xiuer.liveassistant",
  "productName": "秀儿直播助手",
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**",
    "node_modules/playwright/**",
    "node_modules/playwright-core/**"
  ],
  "directories": {
    "app": ".",
    "output": "release/${version}"
  },
  "compression": "maximum",
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "dist-electron/build-config.json",
    "electron/platformConfig.js",
    "electron/main/runtime/**/*",
    "public/**/*",
    "package.json",
    "!**/*.map",
    "!**/*.d.ts",
    "!**/*.tsbuildinfo",
    "!**/test/**",
    "!**/tests/**",
    "!**/docs/**",
    "!**/.cache/**",
    "!**/playwright/.cache/**",
    "!**/node_modules/**/*.md",
    "!**/node_modules/**/*.map",
    "!**/node_modules/**/CHANGELOG*",
    "!**/node_modules/**/LICENSE*",
    "!**/node_modules/**/README*",
    "!**/node_modules/**/.github/**",
    "!**/node_modules/**/docs/**",
    "!**/node_modules/**/examples/**",
    "!**/node_modules/**/test/**",
    "!**/node_modules/**/tests/**",
    "!**/node_modules/**/__tests__/**",
    "!**/node_modules/**/*.ts",
    "!**/node_modules/**/*.flow",
    "!**/node_modules/**/*.coffee",
    "!**/node_modules/**/.eslintrc*",
    "!**/node_modules/**/.prettierrc*",
    "!**/node_modules/**/tsconfig.json",
    "!**/node_modules/**/webpack.config.js",
    "!**/node_modules/**/rollup.config.js",
    "!**/node_modules/**/vite.config.js",
    "!**/node_modules/**/*.d.ts",
    "!**/node_modules/**/*.test.js",
    "!**/node_modules/**/*.spec.js",
    "!**/node_modules/**/jest.config.*",
    "!**/node_modules/**/babel.config.*",
    "!**/node_modules/**/.babelrc*",
    "!**/node_modules/**/.gitignore",
    "!**/node_modules/**/.npmignore",
    "!**/node_modules/**/.editorconfig",
    "!**/node_modules/**/CONTRIBUTING*",
    "!**/node_modules/**/AUTHORS*",
    "!**/node_modules/**/CODE_OF_CONDUCT*",
    "!**/node_modules/**/SECURITY*",
    "!**/node_modules/**/HISTORY*",
    "!**/node_modules/**/CHANGES*",
    "!**/node_modules/**/PATENTS*",
    "!**/node_modules/**/NOTICE*",
    "!**/node_modules/**/COPYING*",
    "!**/node_modules/**/Makefile",
    "!**/node_modules/**/Gulpfile.js",
    "!**/node_modules/**/Gruntfile.js",
    "!**/node_modules/**/.travis.yml",
    "!**/node_modules/**/.appveyor.yml",
    "!**/node_modules/**/.circleci/**",
    "!**/node_modules/**/.vscode/**",
    "!**/node_modules/**/.idea/**",
    "!**/node_modules/**/*.png",
    "!**/node_modules/**/*.jpg",
    "!**/node_modules/**/*.jpeg",
    "!**/node_modules/**/*.gif",
    "!**/node_modules/**/*.svg",
    "!**/node_modules/**/logo.*",
    "!**/node_modules/**/screenshot.*",
    "!**/node_modules/**/demo/**",
    "!**/node_modules/**/benchmark/**",
    "!**/node_modules/**/perf/**",
    "!**/node_modules/**/coverage/**",
    "!**/node_modules/**/.nyc_output/**",
    "!**/node_modules/**/node_modules/**/node_modules/**",
    "!screenshot/**",
    "!**/screenshot/**",
    "!**/*.psd",
    "!**/*.ai",
    "!**/*.sketch",
    "!remotion-video/**",
    "!**/remotion-video/**",
    "!auth-api/data/**",
    "!**/*.db",
    "!**/*.sqlite",
    "!**/*.sqlite3"
  ],
  "afterPack": "scripts/electron-after-pack.js",
  "afterSign": "scripts/notarize.cjs",
  "extraMetadata": {
    "main": "dist-electron/main/index.js"
  },
  "electronLanguages": ["zh-CN", "en-US"],
  "mac": {
    "artifactName": "Xiuer-Live-Assistant_${version}_macos_${arch}.${ext}",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "public/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "electron/entitlements.mac.plist",
    "entitlementsInherit": "electron/entitlements.mac.plist",
    "category": "public.app-category.utilities"
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }, { "target": "zip", "arch": ["x64"] }],
    "icon": "public/icon-win.ico",
    "artifactName": "Xiuer-Live-Assistant_${version}_win-x64.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "differentialPackage": true,
    "installerIcon": "public/favicon.ico",
    "uninstallerIcon": "public/favicon.ico",
    "license": "LICENSE",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "秀儿直播助手"
  },
  "publish": {
    "provider": "generic",
    "url": "https://download.xiuer.work/releases/latest",
    "channel": "latest"
  }
}
