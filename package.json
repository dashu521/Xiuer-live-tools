{
  "name": "xiuer-live-assistant",
  "type": "commonjs",
  "version": "1.2.3",
  "private": true,
  "description": "秀儿直播助手 - 专业直播助手工具",
  "productName": "秀儿直播助手",
  "author": "Live Studio Team",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "scripts": {
    "dev": "cross-env USE_REAL_AUTH=true vite",
    "dev:force": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && vite",
    "build": "node scripts/generate-build-config.js && tsc && vite build && node scripts/copy-runtime-files.js",
    "preview": "vite preview",
    "test": "vitest run",
    "prepare": "husky",
    "bump": "bumpp --no-commit --no-tag --no-push && changelogen --output",
    "release": "node scripts/release.js",
    "analyze": "node scripts/analyze-build.js",
    "analyze:deps": "node scripts/optimize-deps.mjs",
    "analyze:images": "node scripts/optimize-images.mjs",
    "diag:deps": "node scripts/diagnose-deps.mjs",
    "slow-server": "node ./scripts/slow-server.js",
    "dist:clean": "node -e \"require('fs').rmSync('release',{recursive:true,force:true})\"",
    "dist:check": "node scripts/dist-check-appdir.js",
    "dist:validate": "node scripts/validate-windows-build.js",
    "dist:win": "npm run dist:validate && npm run dist:clean && npm run build && npm run dist:check && electron-builder --win --publish never",
    "dist:mac": "npm run dist:clean && npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run dist:clean && npm run build && electron-builder --linux --publish never",
    "release:mac": "npm run release:guard && npm run dist:clean && npm run build && electron-builder --mac",
    "release:win": "npm run dist:clean && npm run build && electron-builder --win",
    "release:guard": "node scripts/release-guard.js",
    "release:audit": "node scripts/release-audit.js",
    "release:notes": "node scripts/generate-release-notes.js",
    "publish": "node scripts/publish.js",
    "publish:confirm": "node scripts/publish-confirm.js",
    "publish:check": "node scripts/publish-check.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "6.6.2",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.50.0",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@praha/byethrow": "^0.8.1",
    "@praha/error-factory": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tailwindcss/postcss": "^4.0.15",
    "@tailwindcss/vite": "^4.1.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.5",
    "@types/semver": "^7.7.0",
    "@types/signale": "^1.4.7",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@welldone-software/why-did-you-render": "10.0.1",
    "ahooks": "^3.8.4",
    "asar": "^3.2.0",
    "builder-util-runtime": "^9.2.10",
    "bumpp": "^10.0.1",
    "changelogen": "^0.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dompurify": "^3.2.6",
    "dotenv": "17.2.3",
    "electron": "^36.3.2",
    "electron-builder": "26.0.12",
    "electron-log": "^5.3.0",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "immer": "^11.0.1",
    "lint-staged": "16.2.3",
    "lodash-es": "^4.17.21",
    "lucide-react": "0.525.0",
    "marked": "16.4.0",
    "motion": "^12.6.2",
    "openai": "5.8.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.1.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.2.4",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2",
    "vite": "^6.0.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "ws": "^8.18.1",
    "yaml": "^2.8.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "lint-staged": {
    "*": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "electron-winstaller"
    ]
  }
}
