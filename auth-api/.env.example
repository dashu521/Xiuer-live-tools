# Auth API 环境变量示例
# 复制为 .env 并填写真实值。本地开发时配置后即可在开发模式下真实收到验证码短信。

# ---------- 短信验证码（开发/生产均可使用） ----------
# 不设置或 dev：仅打日志，不发真实短信
# aliyun_dypns：阿里云短信认证（个人免签，推荐）
# aliyun：阿里云国内短信（需自备签名/模板）
SMS_MODE=aliyun_dypns

# 阿里云 AccessKey（RAM 用户需授予 dypns:SendSmsVerifyCode、dypns:CheckSmsVerifyCode）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# 号码认证控制台 - 赠送签名与模板（见 https://dypns.console.aliyun.com/smsCertParamsConfig/sign 等）
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ---------- 可选：数据库、JWT、CORS 等 ----------
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/auth_db
# JWT_SECRET=change-me-in-production
# CORS_ORIGINS=*
